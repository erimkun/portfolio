@import url('https://fonts.googleapis.com/css2?family=Anton&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&family=JetBrains+Mono:wght@300;400&display=swap');

:root {
  --ink:        #e9e4d6;
  --ink-dim:    rgba(233,228,214,.55);
  --ink-faint:  rgba(233,228,214,.18);
  --section-bg: #020714;
  --section-grad: 220, 240;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body, #root { height: 100%; overflow: hidden; }
body {
  font-family: 'Fraunces', serif;
  color: var(--ink);
  background: #020714;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  cursor: crosshair;
}

/* ── STAGE ── */
.stage {
  position: fixed; inset: 0;
  overflow: hidden;
  background: radial-gradient(120% 80% at 50% 100%, #0d1f3c 0%, #060c1e 55%, var(--section-bg) 100%);
  transition: background 1.2s ease;
}
.stage::before {
  content: "";
  position: absolute; inset: -5%;
  background:
    radial-gradient(40% 30% at 30% 78%, rgba(120,160,220,.14), transparent 60%),
    radial-gradient(35% 25% at 78% 72%, rgba(180,170,220,.10), transparent 60%),
    radial-gradient(70% 40% at 50% 110%, rgba(90,120,180,.18), transparent 60%);
  filter: blur(4px);
  pointer-events: none;
}
.stars-canvas {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  pointer-events: none;
}

/* ── CHROME (date / time) ── */
.chrome {
  position: absolute; top: 48px; left: 0; right: 0;
  display: flex; flex-direction: column; align-items: center;
  gap: 6px;
  pointer-events: none;
  z-index: 4;
}
.chrome-date {
  font-family: 'JetBrains Mono', monospace;
  font-weight: 300; font-size: 11px;
  letter-spacing: .32em; text-transform: uppercase;
  color: var(--ink-dim);
}
.chrome-time {
  font-family: 'Fraunces', serif;
  font-weight: 300;
  font-variation-settings: "opsz" 144;
  font-size: 92px; line-height: 1;
  letter-spacing: -.04em;
  color: var(--ink);
  text-shadow: 0 2px 40px rgba(120,160,220,.25);
}

/* ── EYES ── */
.eyes {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -54%);
  display: flex; gap: 64px;
  z-index: 3;
}
.eye {
  position: relative;
  width: 240px; height: 240px;
  filter: drop-shadow(0 18px 38px rgba(0,0,0,.55))
          drop-shadow(0 0 30px rgba(140,175,255,.18));
  will-change: transform;
}
.eye svg { width: 100%; height: 100%; display: block; overflow: visible; }

@keyframes float-l {
  0%,100% { transform: translate(0,0); }
  50%     { transform: translate(0,-8px); }
}
@keyframes float-r {
  0%,100% { transform: translate(0,0); }
  50%     { transform: translate(0,-8px); }
}
.eye   .floater { animation: float-l 7s   ease-in-out infinite;      transform-origin: 50% 55%; display: block; }
.eye.r .floater { animation: float-r 7.4s ease-in-out infinite -2.2s; }

/* ── CAPTION ── */
.caption {
  position: absolute; left: 0; right: 0; bottom: 14%;
  text-align: center; z-index: 4; pointer-events: none;
}
.caption-hint {
  font-family: 'Fraunces', serif;
  font-style: italic; font-weight: 300;
  font-size: 30px; letter-spacing: .01em;
  color: var(--ink); opacity: .92;
  transition: opacity .4s ease;
}
.caption-sub {
  margin-top: 14px;
  font-family: 'JetBrains Mono', monospace;
  font-weight: 300; font-size: 10.5px;
  letter-spacing: .42em; text-transform: uppercase;
  color: var(--ink-dim);
  transition: opacity .4s ease;
}

/* ── INK CANVAS ── */
.ink-canvas {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  z-index: 5;
}

/* ── BRAND / STATUS ── */
.brand {
  position: absolute; top: 48px; left: 40px;
  z-index: 4;
  color: var(--ink-dim);
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: .42em; text-transform: uppercase;
}
.status {
  position: absolute; top: 48px; right: 40px;
  display: flex; gap: 14px; align-items: center;
  z-index: 4;
  color: var(--ink-dim);
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: .3em; text-transform: uppercase;
}
.status-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--ink); opacity: .7;
  box-shadow: 0 0 10px rgba(233,228,214,.5);
}

/* ── RESET BUTTON ── */
.reset-btn {
  position: absolute; bottom: 36px; left: 50%;
  transform: translateX(-50%);
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: .3em; text-transform: uppercase;
  color: var(--ink-dim);
  background: transparent;
  border: 1px solid var(--ink-faint);
  padding: 10px 20px; border-radius: 999px;
  cursor: pointer; z-index: 6;
  transition: color .25s, border-color .25s;
}
.reset-btn:hover { color: var(--ink); border-color: var(--ink-dim); }

/* ── SHOCKWAVE ── */
.wave {
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%,-50%);
  width: 10px; height: 10px; border-radius: 50%;
  border: 1px solid rgba(200,220,255,.6);
  pointer-events: none; z-index: 9;
}
@keyframes ripple {
  from { width: 10px;   height: 10px;   opacity: .9; }
  to   { width: 2400px; height: 2400px; opacity: 0;  }
}
.wave.go { animation: ripple 1.4s ease-out forwards; }

/* ── SCENE COLLAPSE (on success) ── */
.stage.collapsing .brand,
.stage.collapsing .status,
.stage.collapsing .chrome,
.stage.collapsing .eyes,
.stage.collapsing .caption {
  opacity: 0 !important;
  transition: opacity .28s ease;
  pointer-events: none;
}


.particle-canvas {
  position: fixed; inset: 0;
  width: 100%; height: 100%;
  z-index: 0; pointer-events: none;
}
.unlock-content {
  position: relative; z-index: 2;
  width: 100%; padding: 0 3vw;
  display: flex; flex-direction: column;
  align-items: center; gap: 28px;
}
.unlocked-title {
  width: 100%;
  display: flex; justify-content: center;
  align-items: center;
  line-height: 0.88; gap: clamp(2px, 0.6vw, 10px);
}
.name-word {
  font-family: 'Anton', sans-serif;
  font-size: clamp(72px, 18vw, 280px);
  font-weight: 400; color: #ffffff;
  letter-spacing: -0.01em; text-transform: uppercase;
  opacity: 0; transform: translateY(55px);
  transition: opacity .85s cubic-bezier(.16,1,.3,1),
              transform .95s cubic-bezier(.16,1,.3,1);
  text-shadow: 0 0 120px rgba(180,210,255,.12);
  white-space: nowrap;
}
.name-word.in { opacity: 1; transform: translateY(0); }

.pixel-logo {
  height: clamp(96px, 21vw, 340px);
  width: auto; object-fit: contain;
  image-rendering: pixelated; image-rendering: crisp-edges;
  flex-shrink: 0;
  visibility: hidden; /* voxels on the lock-screen canvas are the logo; img only provides layout + measurement */
}

.unlocked-sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px; letter-spacing: .42em; text-transform: uppercase;
  color: rgba(233,228,214,.38);
  opacity: 0; transform: translateY(16px);
  transition: opacity .6s ease, transform .6s ease;
}
.unlocked-sub.in { opacity: 1; transform: translateY(0); }

@media (max-width: 600px) {
  .unlocked-title { flex-direction: column; justify-content: center; gap: 10px; }
  .name-word  { font-size: clamp(64px, 22vw, 140px); }
  .pixel-logo { height: clamp(60px, 20vw, 100px); }
}

/* ════════════════════════════════════════════════════════════
   ABOUT SECTION — Biometric Data Panel
   ════════════════════════════════════════════════════════════ */
.about-section {
  min-height: 100vh;
  padding: 10vh 6vw 14vh;
  display: flex; align-items: center;
  position: relative;
}

.about-grid {
  width: 100%; max-width: 1320px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: minmax(280px, 0.9fr) 1.1fr;
  gap: clamp(32px, 5vw, 80px);
  align-items: center;
}

/* ── LEFT: photo ─────────────────────────────── */
.about-photo {
  position: relative;
  display: flex; flex-direction: column; gap: 14px;
}

.photo-frame {
  position: relative;
  aspect-ratio: 3 / 4;
  width: 100%;
  background: #050a18;
  padding: 14px;
  border: 2px solid rgba(233,228,214,.82);
  box-shadow:
    0 30px 80px rgba(0,0,0,.55),
    0 0 0 1px rgba(233,228,214,.08),
    0 0 60px rgba(140,175,255,.10);
  overflow: hidden;
  transform: rotate(-0.6deg);
}
/* rough/irregular white border */
.photo-frame::before {
  content: "";
  position: absolute; inset: 0;
  border: 6px solid #f4efe1;
  clip-path: polygon(
    0% 2%, 1.5% 0%, 6% 1%, 14% 0.4%, 28% 1.6%, 42% 0%, 58% 1.2%, 71% 0.3%,
    86% 1.8%, 96% 0%, 100% 3%, 99% 14%, 100% 28%, 99.2% 44%, 100% 60%,
    98.8% 74%, 100% 88%, 99% 97%, 97% 100%, 86% 99%, 71% 100%, 55% 99%,
    40% 100%, 24% 99%, 9% 100%, 2% 99%, 0% 96%, 1% 82%, 0% 68%, 0.6% 52%,
    0% 38%, 0.8% 22%, 0% 10%
  );
  pointer-events: none;
  filter: drop-shadow(0 0 0.5px rgba(0,0,0,.4));
  z-index: 4;
}

.photo-real,
.photo-pixel {
  position: absolute;
  inset: 14px;
  width: calc(100% - 28px);
  height: calc(100% - 28px);
  object-fit: cover;
  user-select: none;
  -webkit-user-drag: none;
}
.photo-real {
  filter: grayscale(0.18) contrast(1.05) brightness(0.92);
  opacity: 0;
  transition: opacity 1.4s cubic-bezier(.16,.75,.3,1) .2s, filter 1.1s ease;
  z-index: 1;
}
.photo-pixel {
  object-fit: contain;
  image-rendering: pixelated;
  background: radial-gradient(circle at 50% 55%, #0b1636, #030815 70%);
  transition: opacity .78s steps(12, end), transform 1.2s cubic-bezier(.2,.7,.2,1), filter .88s steps(9, end);
  z-index: 2;
  filter: drop-shadow(0 0 12px rgba(255,90,80,.35));
}
.about-section.revealed .photo-real { opacity: 1; }
.about-section.revealed .photo-pixel {
  opacity: 0;
  transform: translateY(-4%) scale(1.04);
  filter: blur(8px) brightness(1.2) saturate(1.6);
}

.photo-dust {
  position: absolute; inset: 14px;
  width: calc(100% - 28px);
  height: calc(100% - 28px);
  z-index: 3; pointer-events: none;
  mix-blend-mode: screen;
}

/* scan-line reveal */
.scan-line {
  position: absolute;
  left: 14px; right: 14px;
  top: 14px;
  height: 3px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(140,200,255,.0) 5%,
    rgba(180,220,255,.85) 50%,
    rgba(140,200,255,.0) 95%,
    transparent 100%
  );
  box-shadow: 0 0 18px rgba(140,200,255,.6), 0 0 40px rgba(140,200,255,.3);
  opacity: 0;
  z-index: 3; pointer-events: none;
}
.about-section.revealed .scan-line {
  animation: scan 1.9s cubic-bezier(.55,.05,.4,1) .2s forwards;
}
@keyframes scan {
  0%   { opacity: 0; transform: translateY(0); }
  8%   { opacity: 1; }
  92%  { opacity: 1; }
  100% { opacity: 0; transform: translateY(calc(100% - 3px)); }
}

/* corners */
.frame-corner {
  position: absolute;
  width: 22px; height: 22px;
  border: 1px solid rgba(180,210,255,.55);
  z-index: 5; pointer-events: none;
}
.frame-corner.tl { top: -6px; left: -6px; border-right: none; border-bottom: none; }
.frame-corner.tr { top: -6px; right: -6px; border-left: none; border-bottom: none; }
.frame-corner.bl { bottom: -6px; left: -6px; border-right: none; border-top: none; }
.frame-corner.br { bottom: -6px; right: -6px; border-left: none; border-top: none; }

.photo-meta {
  display: flex; justify-content: space-between;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: .34em; text-transform: uppercase;
  color: rgba(233,228,214,.42);
  padding: 0 4px;
}

/* ── RIGHT: data panels ─────────────────────── */
.about-data {
  display: flex; flex-direction: column;
  gap: 28px;
  color: var(--ink);
}

.data-head { position: relative; }
.data-tag {
  display: inline-block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: .42em; text-transform: uppercase;
  color: rgba(180,210,255,.75);
  margin-bottom: 14px;
}
.data-title {
  font-family: 'Anton', sans-serif;
  font-weight: 400;
  font-size: clamp(32px, 4.2vw, 62px);
  line-height: 1; letter-spacing: 0.005em;
  text-transform: uppercase;
  color: #f5f0e2;
  text-shadow: 0 0 40px rgba(140,175,255,.22);
}
.data-title-sep {
  color: rgba(180,210,255,.6);
  margin: 0 .2em 0 .05em;
}
.data-title-name {
  display: inline-block;
  background: linear-gradient(92deg, #e9e4d6 0%, #bfd0ff 60%, #e9e4d6 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.data-underline {
  margin-top: 14px;
  height: 1px;
  background: linear-gradient(90deg,
    rgba(180,210,255,.55) 0%,
    rgba(180,210,255,.1) 40%,
    transparent 100%);
}

.data-panel {
  position: relative;
  padding: 24px 26px;
  background: linear-gradient(
    145deg,
    rgba(12,22,46,.55) 0%,
    rgba(8,14,32,.35) 100%
  );
  border: 1px solid rgba(180,210,255,.18);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.04),
    0 20px 60px rgba(0,0,0,.35);
  overflow: hidden;
}
.data-panel::before {
  content: "";
  position: absolute; inset: 0;
  background: linear-gradient(180deg,
    rgba(180,210,255,.08) 0%, transparent 14%);
  pointer-events: none;
}
.panel-noise {
  position: absolute; inset: 0;
  background-image:
    repeating-linear-gradient(
      0deg,
      rgba(180,210,255,.035) 0 1px,
      transparent 1px 3px);
  pointer-events: none;
  mix-blend-mode: overlay;
}
.data-body {
  position: relative;
  font-family: 'Fraunces', serif;
  font-weight: 300;
  font-size: clamp(14px, 1.05vw, 17px);
  line-height: 1.75;
  color: rgba(233,228,214,.88);
  letter-spacing: .005em;
}

.data-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: rgba(180,210,255,.12);
  border: 1px solid rgba(180,210,255,.12);
}
.stat {
  padding: 16px 20px;
  background: rgba(8,14,32,.55);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  display: flex; flex-direction: column; gap: 6px;
}
.stat dt {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9.5px; letter-spacing: .42em; text-transform: uppercase;
  color: rgba(180,210,255,.6);
}
.stat dd {
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px; letter-spacing: .18em;
  color: #f5f0e2;
  display: flex; align-items: center; gap: 8px;
}
.stat-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: #a7f3b7;
  box-shadow: 0 0 10px #7cf0a2, 0 0 2px #fff inset;
  animation: pulse 1.8s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { opacity: 1; transform: scale(1); }
  50%     { opacity: .55; transform: scale(.82); }
}


@media (max-width: 900px) {
  .about-grid { grid-template-columns: 1fr; gap: 40px; }
  .about-section { padding: 8vh 6vw 12vh; }
  .data-stats { grid-template-columns: 1fr; }
}

/* ── SITE SHELL ──────────────────────────────────────────── */
.site-shell {
  position: fixed; inset: 0;
  display: flex; align-items: stretch;
  background: transparent;
  z-index: 10;
  opacity: 0; pointer-events: none;
  transition: opacity 0.9s ease, filter 1.1s ease .15s;
  filter: blur(14px);
}
.site-shell.on { opacity: 1; pointer-events: auto; filter: blur(0); }

.shell-scroll {
  position: relative; z-index: 2;
  width: 100%; height: 100vh;
  overflow-y: auto; overflow-x: hidden;
  scroll-snap-type: y mandatory;
  overscroll-behavior-y: contain;
  scroll-behavior: smooth;
  scrollbar-width: thin;
  scrollbar-color: rgba(233,228,214,.18) transparent;
}
.shell-scroll::-webkit-scrollbar { width: 5px; }
.shell-scroll::-webkit-scrollbar-thumb { background: rgba(233,228,214,.15); border-radius: 3px; }

/* ── SECTION BASE ────────────────────────────────────────── */
.portfolio-section {
  position: relative;
  min-height: 100vh;
  scroll-snap-align: start;
  scroll-snap-stop: always;
}
.section-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 12vh 0 8vh;
}
.hero-section {
  display: flex; align-items: center; justify-content: center;
  padding: 0 3vw;
}

/* ── DOT NAV ─────────────────────────────────────────────── */
.dot-nav {
  position: fixed;
  right: 28px; top: 50%;
  transform: translateY(-50%);
  display: flex; flex-direction: column;
  gap: 18px; align-items: flex-end;
  z-index: 30;
}
.dot-nav-item {
  background: transparent; border: none; cursor: pointer;
  display: flex; align-items: center; gap: 10px;
  padding: 4px 0;
}
.dot-nav-dot {
  display: block;
  width: 5px; height: 5px; border-radius: 50%;
  background: rgba(233,228,214,.3);
  transition: width .3s ease, height .3s ease, background .3s ease, box-shadow .3s ease;
  flex-shrink: 0;
}
.dot-nav-item.active .dot-nav-dot,
.dot-nav-item:hover .dot-nav-dot {
  width: 8px; height: 8px;
  background: rgba(233,228,214,.9);
  box-shadow: 0 0 10px rgba(180,210,255,.7);
}
.dot-nav-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; letter-spacing: .38em; text-transform: uppercase;
  color: rgba(233,228,214,.5);
  opacity: 0; transform: translateX(6px);
  transition: opacity .2s ease, transform .2s ease;
  white-space: nowrap; pointer-events: none;
}
.dot-nav-item:hover .dot-nav-label { opacity: 1; transform: translateX(0); }
@media (max-width: 600px) {
  .dot-nav { right: 14px; gap: 14px; }
  .dot-nav-item { min-height: 44px; }
}

/* ── SECTION SHARED ──────────────────────────────────────── */
.section-header { margin-bottom: 56px; }
.section-tag {
  display: block; margin-bottom: 12px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: .42em; text-transform: uppercase;
  color: rgba(180,210,255,.7);
}
.section-title {
  font-family: 'Anton', sans-serif;
  font-size: clamp(56px, 10vw, 120px);
  font-weight: 400; line-height: 0.9;
  color: #f5f0e2;
  text-shadow: 0 0 60px rgba(140,175,255,.15);
}

/* ── EDUCATION ───────────────────────────────────────────── */
.education-section { padding: 12vh 8vw; }
.edu-timeline {
  position: relative;
  padding-left: 48px;
  display: flex; flex-direction: column; gap: 40px;
}
.timeline-line {
  position: absolute; left: 7px; top: 8px; bottom: 8px;
  width: 1px;
  background: linear-gradient(180deg, rgba(180,210,255,.5) 0%, rgba(180,210,255,.08) 100%);
}
.edu-card {
  position: relative;
  opacity: 0; transform: translateX(-16px);
  filter: contrast(1.35) saturate(1.25) blur(.9px) grayscale(0.25);
  transition: opacity .45s steps(8, end), transform .62s cubic-bezier(.2,.75,.2,1), filter .48s steps(6, end);
  overflow: hidden;
}
.edu-card.visible { opacity: 1; transform: translateX(0); filter: none; }
.edu-card:nth-child(2) { transition-delay: .1s; }
.edu-card:nth-child(3) { transition-delay: .2s; }
.edu-card:nth-child(4) { transition-delay: .3s; }
.timeline-dot {
  position: absolute; left: -44px; top: 8px;
  width: 14px; height: 14px; border-radius: 50%;
  background: rgba(8,14,32,.9);
  border: 1px solid rgba(180,210,255,.55);
  box-shadow: 0 0 12px rgba(140,175,255,.3);
}
.edu-card-inner {
  padding: 24px 28px;
  background: rgba(12,22,46,.4);
  border: 1px solid rgba(180,210,255,.12);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.edu-year {
  display: block; margin-bottom: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: .42em;
  color: rgba(180,210,255,.65);
}
.edu-institution {
  font-family: 'Anton', sans-serif;
  font-size: clamp(24px, 3.5vw, 44px);
  font-weight: 400; line-height: 1; margin-bottom: 6px;
  color: #f5f0e2;
}
.edu-degree {
  font-family: 'Fraunces', serif;
  font-size: 14px; font-style: italic; font-weight: 300;
  color: rgba(233,228,214,.65); margin-bottom: 12px;
}
.edu-desc {
  font-family: 'Fraunces', serif; font-weight: 300;
  font-size: clamp(14px, 1vw, 16px); line-height: 1.7;
  color: rgba(233,228,214,.75);
}

/* ── EXPERIENCE ──────────────────────────────────────────── */
.experience-section { padding: 12vh 8vw; }
.exp-list { display: flex; flex-direction: column; }
.exp-item {
  display: grid;
  grid-template-columns: 180px 1fr;
  gap: 0 32px;
  padding: 36px 0;
  border-bottom: 1px solid rgba(180,210,255,.08);
  opacity: 0; transform: translateY(20px);
  filter: contrast(1.28) saturate(1.3) blur(1px) grayscale(0.2);
  transition: opacity .44s steps(8, end), transform .62s cubic-bezier(.2,.75,.2,1), filter .48s steps(6, end);
}
.exp-item.visible { opacity: 1; transform: translateY(0); filter: none; }
.exp-item:nth-child(2) { transition-delay: .15s; }
.exp-item:nth-child(3) { transition-delay: .3s; }
.exp-meta {
  display: flex; flex-direction: column;
  align-items: flex-end; gap: 12px;
  padding-top: 6px;
}
.exp-period {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: .3em; text-transform: uppercase;
  color: rgba(180,210,255,.6); text-align: right;
}
.exp-icon-dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: rgba(8,14,32,.9);
  border: 1px solid rgba(180,210,255,.5);
  box-shadow: 0 0 10px rgba(140,175,255,.3);
  flex-shrink: 0;
}
.exp-company {
  font-family: 'Anton', sans-serif;
  font-size: clamp(28px, 4vw, 54px);
  font-weight: 400; line-height: 0.95; margin-bottom: 8px;
  color: #f5f0e2;
}
.exp-role {
  font-family: 'Fraunces', serif;
  font-size: 14px; font-style: italic; font-weight: 300;
  color: rgba(233,228,214,.6); margin-bottom: 14px;
}
.exp-desc {
  font-family: 'Fraunces', serif; font-weight: 300;
  font-size: clamp(14px, 1vw, 16px); line-height: 1.75;
  color: rgba(233,228,214,.8);
}
@media (max-width: 700px) {
  .exp-item { grid-template-columns: 1fr; gap: 12px; }
  .exp-meta { align-items: flex-start; flex-direction: row; }
}

/* ── PROJECTS ────────────────────────────────────────────── */
.projects-section { padding: 12vh 8vw; }
.proj-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}
.proj-card {
  position: relative;
  display: flex; flex-direction: column;
  background: rgba(12,22,46,.4);
  border: 1px solid rgba(180,210,255,.12);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  text-decoration: none; color: inherit;
  overflow: hidden;
  opacity: 0; transform: translateY(24px);
  filter: contrast(1.28) saturate(1.35) blur(1px);
  transition: opacity .48s steps(8, end), transform .65s cubic-bezier(.2,.75,.2,1), filter .52s steps(7, end), box-shadow .3s ease, border-color .3s ease;
}
.proj-card.visible { opacity: 1; transform: translateY(0); filter: none; }
.proj-card:nth-child(2) { transition-delay: .12s; }
.proj-card:nth-child(3) { transition-delay: .24s; }
.proj-card:nth-child(4) { transition-delay: .36s; }
.proj-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 24px 60px rgba(0,0,0,.45);
  border-color: rgba(180,210,255,.28);
}
.proj-thumb { aspect-ratio: 16/9; overflow: hidden; background: #050a18; position: relative; }
.proj-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; transition: filter .48s steps(8, end); }
.proj-card:not(.visible) .proj-thumb img {
  image-rendering: pixelated;
  filter: contrast(1.35) saturate(1.35) grayscale(0.25);
}
.proj-dither-canvas {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  opacity: 1; transform: scale(1);
  image-rendering: pixelated;
  transition: opacity .48s steps(8, end), transform .52s cubic-bezier(.2,.75,.2,1);
}
.proj-card.visible .proj-dither-canvas {
  opacity: 0;
  transform: scale(1.06);
  pointer-events: none;
}
.proj-thumb-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(145deg, #0a1428, #040810);
}
.proj-info { padding: 24px; flex: 1; }
.proj-name {
  font-family: 'Anton', sans-serif;
  font-size: clamp(22px, 2.5vw, 36px);
  font-weight: 400; line-height: 1; margin-bottom: 10px;
  color: #f5f0e2;
}
.proj-desc {
  font-family: 'Fraunces', serif; font-weight: 300;
  font-size: 14px; line-height: 1.7;
  color: rgba(233,228,214,.75); margin-bottom: 16px;
}
.proj-tech { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; }
.proj-tech li {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; letter-spacing: .3em; text-transform: uppercase;
  padding: 4px 10px;
  border: 1px solid rgba(180,210,255,.2);
  color: rgba(180,210,255,.7);
}
@media (max-width: 700px) { .proj-grid { grid-template-columns: 1fr; } }

/* ── CONTACT ─────────────────────────────────────────────── */
.contact-section { padding: 12vh 8vw; }
.contact-inner { display: flex; flex-direction: column; justify-content: center; min-height: 80vh; }
.contact-icons { list-style: none; padding: 0; margin-top: 56px; display: flex; gap: 32px; flex-wrap: wrap; }
.contact-icon-item {
  opacity: 0; transform: translateY(20px);
  filter: contrast(1.24) saturate(1.3) blur(.8px) grayscale(0.15);
  transition: opacity .42s steps(7, end), transform .52s cubic-bezier(.2,.75,.2,1), filter .46s steps(6, end);
}
.contact-icon-item.visible { opacity: 1; transform: translateY(0); filter: none; }
.contact-icon-link {
  display: flex; flex-direction: column; align-items: center; gap: 12px;
  text-decoration: none; color: inherit;
}
.contact-icon-svg {
  width: 48px; height: 48px;
  filter: invert(1) opacity(0.7);
  transition: filter .25s ease, transform .25s ease;
}
.contact-icon-link:hover .contact-icon-svg { filter: invert(1) opacity(1); transform: translateY(-4px); }
.contact-icon-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; letter-spacing: .4em; text-transform: uppercase;
  color: rgba(233,228,214,.45);
  transition: color .25s ease;
}
.contact-icon-link:hover .contact-icon-label { color: rgba(233,228,214,.85); }

/* ── PIXEL RIVER CANVAS ──────────────────────────────────── */
.river-canvas {
  position: fixed; inset: 0;
  width: 100%; height: 100%;
  z-index: 1;
  pointer-events: none;
  mix-blend-mode: screen;
}
